diff --git a/modules/caddyhttp/listen_linux.go b/modules/caddyhttp/listen_linux.go
new file mode 100644
index 00000000..938adb8d
--- /dev/null
+++ b/modules/caddyhttp/listen_linux.go
@@ -0,0 +1,22 @@
+//go:build linux
+
+package caddyhttp
+
+import (
+	"syscall"
+
+	"go.uber.org/zap"
+	"golang.org/x/sys/unix"
+)
+
+func freeBind(logger *zap.Logger, network, address string, conn syscall.RawConn) error {
+	return conn.Control(func(descriptor uintptr) {
+		if err := unix.SetsockoptInt(int(descriptor), unix.SOL_IP, syscall.IP_FREEBIND, 1); err != nil {
+			logger.Error("setting SO_FREEBIND",
+				zap.String("network", network),
+				zap.String("address", address),
+				zap.Uintptr("descriptor", descriptor),
+				zap.Error(err))
+		}
+	})
+}
